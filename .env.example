# docs-mcp Environment Configuration Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# CORE CONFIGURATION
# =============================================================================

# Environment (development, production)
MCP_ENVIRONMENT=development

# Secret key for session management (generate with: openssl rand -hex 32)
MCP_SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_hex_32

# =============================================================================
# DATABASE CONFIGURATION  
# =============================================================================

# ChromaDB data directory (absolute path recommended)
# For ResaleAnalyzer integration, point to your existing ChromaDB data
MCP_CHROMA_DATA_DIR=/Users/aartemov/dev/resale-analyzer/.chroma_data

# =============================================================================
# API KEYS & EXTERNAL SERVICES
# =============================================================================

# OpenAI API Key (required for embeddings)
# Get from: https://platform.openai.com/api-keys
MCP_OPENAI_API_KEY=your_openai_api_key_here

# GitHub Token (optional, for documentation updates)
# Get from: https://github.com/settings/tokens
MCP_GITHUB_TOKEN=your_github_token_for_doc_updates

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# MCP Server host and port
MCP_HOST=127.0.0.1
MCP_PORT=8000

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# Maximum query length (characters)
MCP_MAX_QUERY_LENGTH=1000

# Rate limiting (requests per minute)
MCP_RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Allowed origins for CORS (comma-separated)
MCP_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
MCP_LOG_LEVEL=INFO

# Log file path (relative to project root)
MCP_LOG_FILE=logs/mcp_server.log

# =============================================================================
# PRODUCTION SETTINGS
# =============================================================================

# For production deployments, ensure:
# 1. Use strong SECRET_KEY (at least 32 characters)
# 2. Set ENVIRONMENT=production
# 3. Use absolute paths for CHROMA_DATA_DIR
# 4. Restrict ALLOWED_ORIGINS to your actual domains
# 5. Set appropriate LOG_LEVEL (INFO or WARNING)
# 6. Never commit actual .env file to version control